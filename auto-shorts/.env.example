# Auto-Shorts — environment template. Copy to .env and fill in.
# Never commit a real .env.

# --- Server ---
PORT=4000
NODE_ENV=development
LOG_LEVEL=info

# Comma-separated allowed origins for the frontend (e.g. the Lovable app URL).
# Leave empty to reflect any origin (dev/demo only — lock this down in prod).
CORS_ORIGINS=

# Per-IP rate limit on /api routes. RATE_LIMIT_MAX=0 disables it (dev default);
# set a positive cap (e.g. 120) in production. Window is in milliseconds.
RATE_LIMIT_MAX=0
RATE_LIMIT_WINDOW_MS=60000

# --- AI (routed exclusively through the Super Agent) ---
# The ONLY model credential the app needs. App code never sees model strings.
ANTHROPIC_API_KEY=

# Optional model pins (overrides live ONLY in superAgent.ts defaults).
# SUPERAGENT_MODEL_OPUS=
# SUPERAGENT_MODEL_SONNET=
# SUPERAGENT_MODEL_HAIKU=

# --- Transcription / rendering worker ---
# Leave WORKER_URL empty for "standalone" mode (built-in sample transcript; no
# Whisper/FFmpeg). Set it to the worker's URL for real transcription + rendering.
WORKER_URL=
WHISPER_MODEL=base

# --- Datastore ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/auto_shorts

# --- Queue ---
REDIS_URL=redis://localhost:6379

# --- Object storage (S3-compatible; MinIO in dev) ---
S3_ENDPOINT=http://localhost:9000
S3_BUCKET=auto-shorts
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
